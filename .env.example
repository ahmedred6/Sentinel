# -----------------------------------------------------------------------
# Sentinel — environment variables
# Copy to .env and fill in your values. Never commit .env.
# -----------------------------------------------------------------------

# OpenAI — used by the simulation and SDK interceptor
OPENAI_API_KEY=sk-proj-...

# GitHub — used by the fix-generator (Module 5) to open PRs
GITHUB_TOKEN=ghp_...

# PostgreSQL (Supabase / Railway / local)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/postgres

# Redis (Railway / local)
REDIS_URL=redis://localhost:6379

# ClickHouse Cloud (or self-hosted)
CLICKHOUSE_HOST=your-cluster.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DB=default

# Sentinel ingest API — hardcoded for local dev (INGEST-02)
SENTINEL_API_KEY=sk_local_dev

# Customer ID used by the simulation and demo scripts
SENTINEL_CUSTOMER_ID=cust_sim
